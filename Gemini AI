local function buildContextFromSlice(slice)
local contents={}
for i=1,#chatHistory do if chatHistory[i].id~=currentChatId then local msgs=chatHistory[i].messages if msgs then for j=1,math.min(#msgs,20) do contents[#contents+1]={role=msgs[j].isUser and "user" or "model",parts={{text=msgs[j].text}}} end end end end
for i=1,#slice do local m=slice[i] contents[#contents+1]={role=m.isUser and "user" or "model",parts={{text=m.text}}} end
return contents
end

local function switchToNextModel()
local old=MODELS[currentModelIndex].name
if currentModelIndex<#MODELS then currentModelIndex=currentModelIndex+1 else currentModelIndex=1 end
if statusLabelRef and statusLabelRef.Parent then statusLabelRef.Text=tx("status",MODELS[currentModelIndex].name) end
saveData()
return old
end

local MAX_RETRIES = #MODELS

sendToGemini = function(userMessage,myGenId,contextOverride,retryCount)
retryCount = retryCount or 0
if retryCount >= MAX_RETRIES then return tx("apiError", "All models failed") end
if stopGeneration or generationId~=myGenId then return nil end
local mid=MODELS[currentModelIndex].id
local url="https://generativelanguage.googleapis.com/v1beta/"..mid..":generateContent?key="..GEMINI_API_KEY
local contents
if contextOverride then
contents=contextOverride
local lastRole = #contents > 0 and contents[#contents].role or nil
if lastRole ~= "user" then
contents[#contents+1]={role="user",parts={{text=userMessage}}}
end
else
contents=buildContextFromSlice(currentChatMessages)
local lastRole = #contents > 0 and contents[#contents].role or nil
if lastRole ~= "user" then
contents[#contents+1]={role="user",parts={{text=userMessage}}}
end
end
if stopGeneration or generationId~=myGenId then return nil end
local ok,resp=pcall(function() return request({Url=url,Method="POST",Headers={["Content-Type"]="application/json"},Body=HttpService:JSONEncode({contents=contents})}) end)
if stopGeneration or generationId~=myGenId then return nil end
if ok and resp and resp.StatusCode==200 then
local s2,data=pcall(function() return HttpService:JSONDecode(resp.Body) end)
if s2 and data and data.candidates and data.candidates[1] and data.candidates[1].content and data.candidates[1].content.parts and data.candidates[1].content.parts[1] then
return data.candidates[1].content.parts[1].text
end
return tx("unexpectedFormat")
elseif ok and resp then
local old=switchToNextModel()
notify("Gemini AI", tx("switchingModel",old,MODELS[currentModelIndex].name), 3)
if stopGeneration or generationId~=myGenId then return nil end
return sendToGemini(userMessage,myGenId,contextOverride,retryCount+1)
else
local old=switchToNextModel()
notify("Gemini AI", tx("switchingModel",old,MODELS[currentModelIndex].name), 3)
if stopGeneration or generationId~=myGenId then return nil end
return sendToGemini(userMessage,myGenId,contextOverride,retryCount+1)
end
end

