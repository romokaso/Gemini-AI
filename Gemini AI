t.name or "Chat") nb2.TextColor3=Color3.fromRGB(255,255,255) nb2.TextSize=13 nb2.Font=Enum.Font.GothamBold nb2.TextXAlignment=Enum.TextXAlignment.Left nb2.TextTruncate=Enum.TextTruncate.AtEnd nb2.ZIndex=53 nb2.Parent=it local inf=Instance.new("TextLabel") inf.Size=UDim2.new(1,-24,0,16) inf.Position=UDim2.new(0,12,0,28) inf.BackgroundTransparency=1 inf.Text=(chat.lastModel or "").." | "..(chat.lastTime or "") inf.TextColor3=th.subtext inf.TextSize=10 inf.Font=Enum.Font.Gotham inf.TextXAlignment=Enum.TextXAlignment.Left inf.TextTruncate=Enum.TextTruncate.AtEnd inf.ZIndex=53 inf.Parent=it local prv=Instance.new("TextLabel") prv.Size=UDim2.new(1,-24,0,20) prv.Position=UDim2.new(0,12,0,46) prv.BackgroundTransparency=1 prv.Text=chat.lastAiPreview or "" prv.TextColor3=th.subtext prv.TextSize=11 prv.Font=Enum.Font.Gotham prv.TextXAlignment=Enum.TextXAlignment.Left prv.TextTruncate=Enum.TextTruncate.AtEnd prv.ZIndex=53 prv.Parent=it local pinBt=Instance.new("TextButton") pinBt.Size=UDim2.new(0,34,0,34) pinBt.Position=UDim2.new(1,-122,0,6) pinBt.BackgroundColor3=chat.pinned and th.accent or th.headerBtn pinBt.BorderSizePixel=0 pinBt.Text="📌" pinBt.TextColor3=Color3.fromRGB(255,255,255) pinBt.TextSize=14 pinBt.Font=Enum.Font.GothamBold pinBt.ZIndex=53 pinBt.Parent=it mkC(pinBt,8) local eB=Instance.new("TextButton") eB.Size=UDim2.new(0,34,0,34) eB.Position=UDim2.new(1,-82,0,6) eB.BackgroundColor3=th.accent eB.BorderSizePixel=0 eB.Text="✏" eB.TextColor3=Color3.fromRGB(255,255,255) eB.TextSize=14 eB.Font=Enum.Font.GothamBold eB.ZIndex=53 eB.Parent=it mkC(eB,8) local dB2=Instance.new("TextButton") dB2.Size=UDim2.new(0,34,0,34) dB2.Position=UDim2.new(1,-42,0,6) dB2.BackgroundColor3=th.danger dB2.BorderSizePixel=0 dB2.Text="🗑" dB2.TextColor3=Color3.fromRGB(255,255,255) dB2.TextSize=14 dB2.Font=Enum.Font.GothamBold dB2.ZIndex=53 dB2.Parent=it mkC(dB2,8) local cc=chat pinBt.MouseButton1Click:Connect(function() for i=1,#chatHistory do if chatHistory[i].id==cc.id then chatHistory[i].pinned=not chatHistory[i].pinned break end end saveData() refHist(sBox.Text) end) nb2.MouseButton1Click:Connect(function() saveDraft() saveChatToHistory() hideReplyBar() editingMessageIndex=nil currentChatId=cc.id currentChatMessages=cc.messages or {} autoScrollEnabled=true rebuildChat() isHistoryOpen=false TweenService:Create(histFr,TweenInfo.new(0.3,Enum.EasingStyle.Quart),{Position=UDim2.new(-1,0,0,0)}):Play() task.delay(0.3,function() histFr.Visible=false end) saveData() loadDraft() scrollToBottom() end) eB.MouseButton1Click:Connect(function() renamingId=cc.id rnI.Text=cc.name or "" renOv.Visible=true end) dB2.MouseButton1Click:Connect(function() for di=1,#chatHistory do if chatHistory[di].id==cc.id then table.remove(chatHistory,di) break end end chatDrafts[cc.id]=nil if currentChatId==cc.id then currentChatId=nil currentChatMessages={} clearChat() hideReplyBar() editingMessageIndex=nil startNewChat() end saveData() refHist(sBox.Text) end) end else local res={} for hi=1,#chatHistory do local chat=chatHistory[hi] if chat.messages then for mi=1,#chat.messages do local msg2=chat.messages[mi] if msg2.isUser and (query=="" or msg2.text:lower():find(query,1,true)) then res[#res+1]={chat=chat,msgIdx=mi,text=msg2.text} end end end end if #res==0 then local n=Instance.new("TextLabel") n.Size=UDim2.new(1,0,0,50) n.BackgroundTransparency=1 n.Text=tx("noResults") n.TextColor3=th.subtext n.TextSize=15 n.Font=Enum.Font.Gotham n.ZIndex=52 n.Parent=hSc return end for ri,r in ipairs(res) do local it=Instance.new("Frame") it.Size=UDim2.new(1,0,0,60) it.BackgroundColor3=th.button it.BorderSizePixel=0 it.ZIndex=52 it.LayoutOrder=ri it.Parent=hSc mkC(it,10) local cnl=Instance.new("TextLabel") cnl.Size=UDim2.new(1,-16,0,18) cnl.Position=UDim2.new(0,12,0,4) cnl.BackgroundTransparency=1 cnl.Text="💬 "..(r.chat.name or "Chat") cnl.TextColor3=th.accent cnl.TextSize=11 cnl.Font=Enum.Font.GothamBold cnl.TextXAlignment=Enum.TextXAlignment.Left cnl.TextTruncate=Enum.TextTruncate.AtEnd cnl.ZIndex=53 cnl.Parent=it local mLbl=Instance.new("TextButton") mLbl.Size=UDim2.new(1,-16,0,30) mLbl.Position=UDim2.new(0,12,0,24) mLbl.BackgroundTransparency=1 mLbl.Text=string.sub(r.text,1,80) mLbl.TextColor3=th.text mLbl.TextSize=12 mLbl.Font=Enum.Font.Gotham mLbl.TextXAlignment=Enum.TextXAlignment.Left mLbl.TextTruncate=Enum.TextTruncate.AtEnd mLbl.ZIndex=53 mLbl.Parent=it local tChat,tIdx=r.chat,r.msgIdx mLbl.MouseButton1Click:Connect(function() saveDraft() saveChatToHistory() hideReplyBar() editingMessageIndex=nil currentChatId=tChat.id currentChatMessages=tChat.messages or {} autoScrollEnabled=false clearChat() for m2=1,#currentChatMessages do local mm=currentChatMessages[m2] local et2=nil if not mm.isUser and mm.elapsed then et2=mm.elapsed end local frame=createMessage(mm.text,mm.isUser,true,false,m2,et2,mm.replyTo) if m2==tIdx and frame then frame.BackgroundColor3=th.highlight task.delay(3,function() if frame and frame.Parent then TweenService:Create(frame,TweenInfo.new(0.5),{BackgroundColor3=currentChatMessages[m2].isUser and th.userMsg or th.aiMsg}):Play() end end) end end isHistoryOpen=false TweenService:Create(histFr,TweenInfo.new(0.3,Enum.EasingStyle.Quart),{Position=UDim2.new(-1,0,0,0)}):Play() task.delay(0.3,function() histFr.Visible=false end) saveData() autoScrollEnabled=true loadDraft() task.defer(function() task.wait(0.15) if chatFrameRef and chatFrameRef.Parent then local cnt,tY=0,0 for _,child in ipairs(chatFrameRef:GetChildren()) do if child:IsA("Frame") then cnt=cnt+1 if cnt==tIdx then tY=child.AbsolutePosition.Y-chatFrameRef.AbsolutePosition.Y+chatFrameRef.CanvasPosition.Y-50 break end end end chatFrameRef.CanvasPosition=Vector2.new(0,math.max(0,tY)) end end) end) end end end
