local function verifyApiKey(key,cb) task.spawn(function() if #key<20 then cb(false) return end local ok,r=pcall(function() return request({Url="https://generativelanguage.googleapis.com/v1beta/models?key="..key,Method="GET",Headers={["Content-Type"]="application/json"}}) end) if ok and r then if r.StatusCode==200 then cb(true) return elseif r.StatusCode==400 or r.StatusCode==403 then cb(false) return end end if string.sub(key,1,4)=="AIza" and #key>=35 then cb(true) else cb(false) end end) end

local function detectLanguage(code) local map={lua="Lua",luau="Luau",python="Python",py="Python",javascript="JavaScript",js="JavaScript",typescript="TypeScript",ts="TypeScript",java="Java",cpp="C++",c="C",csharp="C#",cs="C#",go="Go",rust="Rust",ruby="Ruby",php="PHP",swift="Swift",kotlin="Kotlin",html="HTML",css="CSS",sql="SQL",bash="Bash",sh="Shell",json="JSON",xml="XML",yaml="YAML",dart="Dart",scala="Scala",r="R",jsx="JSX",tsx="TSX"} if code and code~="" then local lower=code:lower() if map[lower] then return map[lower] end return code:sub(1,1):upper()..code:sub(2):lower() end return "Code" end

local function extractCodeBlocks(text) local parts={} local lastEnd=1 for startPos,lang,code,endPos in text:gmatch("()```(%w*)\n(.-)\n```()") do if startPos>lastEnd then table.insert(parts,{type="text",content=text:sub(lastEnd,startPos-1)}) end table.insert(parts,{type="code",language=lang,content=code}) lastEnd=endPos end if lastEnd<=#text then table.insert(parts,{type="text",content=text:sub(lastEnd)}) end if #parts==0 then table.insert(parts,{type="text",content=text}) end return parts end

local function typeText(label,text,chunkSize,delay,myGenId) if not label or not label.Parent then return end label.Text="" local i=1 while i<=#text do if myGenId and generationId~=myGenId then return end if stopGeneration then return end if not label or not label.Parent then return end local endIdx=math.min(i+chunkSize-1,#text) label.Text=label.Text..text:sub(i,endIdx) i=endIdx+1 if autoScrollEnabled and i%24==0 then scrollToBottom() end if delay>0 then task.wait(delay) else RunService.Heartbeat:Wait() end end if autoScrollEnabled then scrollToBottom() end end

